# Copy to `.env.local` for Next.js local development against Supabase CLI.
# Start the stack: `npm run supabase:start`, then paste values from `npm run supabase:status`.

NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321

# Placeholders only — replace with the anon and service_role keys from `npm run supabase:status`.
NEXT_PUBLIC_SUPABASE_ANON_KEY=PASTE_LOCAL_ANON_KEY_FROM_SUPABASE_STATUS
SUPABASE_SERVICE_ROLE_KEY=PASTE_LOCAL_SERVICE_ROLE_KEY_FROM_SUPABASE_STATUS

# Local Postgres URL: use user, password, host, and port from `supabase status` (defaults are documented in Supabase local dev guides).
DATABASE_URL=postgresql://postgres:PASTE_LOCAL_DB_PASSWORD@127.0.0.1:54322/postgres
